# Конфигурация для локального запуска llm-api
# Скопируйте в docs/deploy/to-local-machine/.env

# ============================================
# LLM API КОНФИГУРАЦИЯ
# ============================================

# Модель для использования
# Варианты: llama-3.2-3b-instruct, llama-3.2-1b-instruct
LLAMA_MODEL=llama-3.2-3b-instruct

# GPU поддержка (требуется NVIDIA Container Toolkit + драйверы)
GPU_ENABLED=true

# Параметры генерации
CONTEXT_SIZE=2048
MAX_TOKENS=512

# Путь к локальной модели (опционально, для offline использования)
# Если не указан, модель будет скачана из HuggingFace
LOCAL_MODEL_PATH=

# ============================================
# ЛОГИРОВАНИЕ
# ============================================
LOG_LEVEL=INFO
LOG_JSON=false

